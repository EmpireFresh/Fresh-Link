# .env.example — Copiez en .env et remplissez les valeurs
# NE COMMITEZ JAMAIS .env dans Git !

# ── Supabase ────────────────────────────────────────────────────────────────
# Disponibles dans : Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # clé "service_role"

# ── Green API (WhatsApp groupe) ────────────────────────────────────────────
# Inscrivez-vous sur https://green-api.com (compte gratuit disponible)
# Après connexion de votre numéro WhatsApp, récupérez :
GREEN_API_INSTANCE=1101234567         # votre idInstance
GREEN_API_TOKEN=d75b3a66374942c5b3c650......   # votre apiTokenInstance

# ID du groupe WhatsApp destinataire
# Format : 120363XXXXXXXXXX@g.us
# Comment le trouver :
#   1. Ouvrez web.whatsapp.com
#   2. Ouvrez le groupe cible
#   3. L'URL contient l'ID : web.whatsapp.com/...#120363XXXXXXXXXX@g.us
#   Ou appelez : GET https://api.green-api.com/waInstance{ID}/getContacts/{TOKEN}
WA_GROUP_ID=120363XXXXXXXXXX@g.us

# ── Alternative : UltraMsg ─────────────────────────────────────────────────
# Si vous utilisez UltraMsg au lieu de Green API (décommentez dans submit.js)
# ULTRAMSG_INSTANCE=instance12345
# ULTRAMSG_TOKEN=xxxxxxxxxxxxxxxx
