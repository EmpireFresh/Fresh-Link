# ══════════════════════════════════════════════════════════════════════════════
# FreshLink Empire Fresh — Variables d'Environnement
# ⚠️  COPIEZ CE FICHIER en .env.local et remplissez vos vraies valeurs
# ⚠️  Ne jamais committer .env.local dans Git !
# ══════════════════════════════════════════════════════════════════════════════

# ── 1. SUPABASE ───────────────────────────────────────────────────────────────
# Votre projet : https://supabase.com/dashboard/project/jwdrwapuetqoqnankgma
# Clés disponibles dans : Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://jwdrwapuetqoqnankgma.supabase.co

# Anon Key (public — safe to expose) :
# Dashboard → Settings → API → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLLER_VOTRE_ANON_KEY_ICI

# Service Role Key (PRIVÉ — jamais côté client) :
# Dashboard → Settings → API → "service_role secret"
SUPABASE_SERVICE_ROLE_KEY=COLLER_VOTRE_SERVICE_ROLE_KEY_ICI

# ── 2. STORAGE BUCKET ─────────────────────────────────────────────────────────
# Bucket existant : freshlink-media
# Photos articles déjà uploadées ✓
# URL publique format : https://jwdrwapuetqoqnankgma.supabase.co/storage/v1/object/public/freshlink-media/[path]
NEXT_PUBLIC_STORAGE_BUCKET=freshlink-media

# ── 3. AGENTS IA (Anthropic Claude — Recommandé) ─────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# Modèle utilisé par les agents JAWAD, ZIZI, ASHEL, JARIRI, etc.
NEXT_PUBLIC_AI_MODEL=claude-sonnet-4-20250514

# ── 4. EMAIL — NEO.SPACE ──────────────────────────────────────────────────────
# Neo.space → My Account → Mail → SMTP Settings
# https://app.neo.space → Mail Setup
SMTP_HOST=smtp.neo.space
SMTP_PORT=587
SMTP_USER=votre-email@empire-fresh.co.site
SMTP_PASS=VOTRE_MOT_DE_PASSE_NEO
SMTP_FROM="FreshLink Empire Fresh <no-reply@empire-fresh.co.site>"

# Email rapport journalier (vers Gmail)
DAILY_REPORT_EMAIL=fresh.empire.contact@gmail.com

# ── 5. APPLICATION ────────────────────────────────────────────────────────────
# Netlify : https://empire-fresh.netlify.app
# Vercel  : https://freshlink-empire-fresh.vercel.app (ou votre domaine custom)
NEXT_PUBLIC_APP_URL=https://empire-fresh.netlify.app

# ── 6. WHATSAPP BUSINESS (Optionnel) ─────────────────────────────────────────
# https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_TOKEN=VOTRE_TOKEN_WHATSAPP
WHATSAPP_PHONE_ID=VOTRE_PHONE_ID

# ── 7. GOOGLE SHEETS (Export données, optionnel) ─────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=freshlink@votre-projet.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nVOTRE_CLE_PRIVEE\n-----END PRIVATE KEY-----"

# ── 8. ALERTES N3 ────────────────────────────────────────────────────────────
NEXT_PUBLIC_N3_ALERT_PHONE=+212663898707

# ── 9. FIREBASE (Archivage Supabase → Firestore) ──────────────────────────────
# Quand le quota Supabase free (500 MB) approche, archivez les anciennes données
# vers Firebase Firestore (gratuit jusqu'à 1 GB).
#
# Comment obtenir ces valeurs :
# 1. Allez sur https://console.firebase.google.com
# 2. Créez un nouveau projet (ou sélectionnez un existant)
# 3. Ajoutez une application Web (icône </> dans "Aperçu du projet")
# 4. Copiez la configuration affichée (firebaseConfig)
# 5. Activez Firestore Database → mode Production → région europe-west1
#
NEXT_PUBLIC_FIREBASE_API_KEY=VOTRE_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=votre-projet-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=votre-projet.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdefghijklmnop
