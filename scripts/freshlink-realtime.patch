+      </div>
+    </div>
+  </div>
+</div>
+</body>
+</html>`
+}
+
+function printDocument(doc: Document, company: CompanyConfig) {
+  const html = generateDocumentHTML(doc, company)
+  const w = window.open("", "_blank", "width=950,height=700")
+  if (!w) return
+  w.document.write(html)
+  w.document.close()
+  w.focus()
+  setTimeout(() => { w.print() }, 500)
+}
